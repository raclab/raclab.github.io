      <h1 data-i18n="hero_title">R A C L A B</h1>
      <h3 data-i18n="hero_subtitle">Innovating Autonomous Systems</h3>

      <!-- ADD BUTTON -->
      <a href="pages/contact.html" class="header-btn" data-i18n="hero_btn">Contact Us</a>
   </header>

   <!-- WHAT WE DO SECTION -->
   <section class="what-we-do target">
      <div class="wrapper">
         <div class="wwd-header">
            <img src="public/img/user/raclab.png" alt="RACLAB" class="wwd-logo">
            <span class="wwd-label" data-i18n="whatwedo_label">RACLAB TEAM</span>
            <h2 class="wwd-title" data-i18n="whatwedo_title">WHAT WE DO</h2>
            <div class="wwd-line"></div>
         </div>
         <div class="gallery">
            <!-- Card 1 -->
            <div class="card" id="airframe-design">
               <div class="card-icon"><i class="fa-solid fa-plane-up"></i></div>
               <div class="card-divider"></div>
               <div class="content">
                  <h3 data-i18n="wwd_card1_title">Airframe Design</h3>
                  <p data-i18n="wwd_card1_desc">We manufacture our airframes using advanced 3D printing technologies
                     with high-quality thermoplastic filaments such as PLA and reinforced polymers. We optimize our
                     structures for lightweight performance, structural strength, and aerodynamic efficiency to ensure
                     reliable, mission-ready flight operations.</p>
               </div>
            </div>

            <!-- Card 2 -->
            <div class="card" id="intelligent-sensing">
               <div class="card-icon"><i class="fa-solid fa-satellite-dish"></i></div>
               <div class="card-divider"></div>
               <div class="content">
                  <h3 data-i18n="wwd_card2_title">Intelligent Sensing</h3>
                  <p data-i18n="wwd_card2_desc">We integrate onboard sensor fusion and real-time data processing to
                     enable accurate target detection, environmental mapping, and enhanced situational awareness during
                     mission operations.</p>
               </div>
            </div>

            <!-- Card 3 -->
            <div class="card" id="autonomous-control">
               <div class="card-icon"><i class="fa-solid fa-microchip"></i></div>
               <div class="card-divider"></div>
               <div class="content">
                  <h3 data-i18n="wwd_card3_title">Autonomous Control</h3>
                  <p data-i18n="wwd_card3_desc">We develop precision flight algorithms that integrate PID-based control
                     systems for flight stabilization and SLAM-driven localization and mapping for accurate navigation.
                     By combining real-time sensor feedback with advanced autonomy frameworks, we ensure stable flight
                     performance, reliable obstacle avoidance, and adaptive decision-making throughout every autonomous
                     mission.</p>
               </div>
            </div>

            <!-- Card 4 -->
            <div class="card" id="payload-integration">
               <div class="card-icon"><i class="fa-solid fa-box-open"></i></div>
               <div class="card-divider"></div>
               <div class="content">
                  <h3 data-i18n="wwd_card4_title">Payload Integration</h3>
                  <p data-i18n="wwd_card4_desc">We design, develop, and test custom payload systems tailored to meet
                     mission-specific requirements. We ensure reliable, repeatable performance and seamless integration
                     with our airframe and onboard systems to support efficient and mission-ready operations.</p>
               </div>
            </div>

            <!-- Card 5 -->
            <div class="card" id="ground-control">
               <div class="card-icon"><i class="fa-solid fa-tower-broadcast"></i></div>
               <div class="card-divider"></div>
               <div class="content">
                  <h3 data-i18n="wwd_card5_title">Ground Control System</h3>
                  <p data-i18n="wwd_card5_desc">We develop a C++-based ground control application designed for reliable
                     mission planning, real-time telemetry monitoring, and secure command transmission. Our system
                     provides a robust and responsive interface for flight control, data visualization, and operational
                     management, ensuring stable communication and efficient mission execution.</p>
               </div>
            </div>

            <!-- Card 6 -->
            <div class="card" id="research-development">
               <div class="card-icon"><i class="fa-solid fa-rocket"></i></div>
               <div class="card-divider"></div>
               <div class="content">
                  <h3 data-i18n="wwd_card6_title">Research & Development</h3>
                  <p data-i18n="wwd_card6_desc">Pushing the boundaries of UAV technology through continuous research,
                     iterative prototyping, and real-world testing.</p>
               </div>
            </div>
         </div>
      </div>
   </section>

   <section class="our-mission-section target" id="mission">
      <div class="mission-container">
         <div class="mission-header">
            <h2 data-i18n="mission_title">OUR MISSION</h2>
            <p data-i18n="mission_subtitle">RACLAB empowers undergraduate engineers to transform technical knowledge
               into real-world autonomous systems through national and international competitions.</p>
         </div>

         <div class="mission-grid">
            <!-- UAV Card -->
            <div class="mission-card uav-card">
               <div class="mission-bg-particles"></div>
               <div class="mission-content">
                  <div class="mission-icon">
                     <i class="fa-solid fa-plane-up"></i>
                  </div>
                  <h3 data-i18n="mission_uav_title">RACLAB UAV</h3>
                  <p class="mission-desc" data-i18n="mission_uav_desc">Focused on aerial autonomy, intelligent
                     navigation, mission planning, and advanced drone systems.</p>

                  <div class="mission-comp">
                     <span class="comp-label" data-i18n="mission_comp_label">COMPETITION</span>
                     <span class="comp-name">SUAS 2026</span>
                     <a href="https://suas-competition.org/" target="_blank" rel="noopener noreferrer"
                        class="comp-logo-link">
                        <img src="public/img/user/suas_logo.jpg" alt="SUAS Logo">
                     </a>
                  </div>
               </div>
            </div>

            <!-- Underwater Card -->
            <div class="mission-card underwater-card">
               <div class="mission-water-effect"></div>
               <div class="mission-content">
                  <div class="mission-icon">
                     <i class="fa-solid fa-water"></i>
                  </div>
                  <h3 data-i18n="mission_underwater_title">RACLAB Underwater</h3>
                  <p class="mission-desc" data-i18n="mission_underwater_desc">Focused on underwater robotics, perception
                     systems, autonomous control, and marine technologies.</p>

                  <div class="mission-comp">
                     <span class="comp-label" data-i18n="mission_comp_label">COMPETITION</span>
                     <span class="comp-name">RoboSub 2026</span>
                     <a href="https://robosub.org/" target="_blank" rel="noopener noreferrer" class="comp-logo-link">
                        <img src="public/img/user/robosub.png" alt="RoboSub Logo">
                     </a>
                  </div>
               </div>
            </div>
         </div>

         <div class="mission-footer">
            <span data-i18n="mission_footer">Two Domains. One Vision.</span>
         </div>
      </div>
   </section>



